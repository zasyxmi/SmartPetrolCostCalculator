<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/aboutScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <!-- Main About page layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Application icon -->
        <!-- For now, we use the default launcher foreground icon -->
        <ImageView
            android:id="@+id/imgAppIcon"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginTop="20dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/my_logo"/>

        <!-- About title -->
        <TextView
            android:id="@+id/tvAboutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/about_title"
            android:textColor="#1B5E20"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- About description -->
        <TextView
            android:id="@+id/tvAboutDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/about_description"
            android:textColor="#555555"
            android:textSize="15sp" />

        <!-- Author information card -->
        <LinearLayout
            android:id="@+id/authorCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvAuthorSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Author Information"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAuthorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/author_name"
                android:textColor="#222222"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvMatricNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/matric_no"
                android:textColor="#222222"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvCourseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/course_name"
                android:textColor="#222222"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- GitHub repository card -->
        <LinearLayout
            android:id="@+id/githubCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvGithubLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/github_label"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- This TextView will be made clickable in AboutFragment.java -->
            <TextView
                android:id="@+id/tvGithubUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/github_url"
                android:textColor="#1565C0"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Copyright notice -->
        <TextView
            android:id="@+id/tvCopyright"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/copyright_notice"
            android:textColor="#777777"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>