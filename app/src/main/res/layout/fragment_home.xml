<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <!-- Main vertical layout for calculator content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Home title -->
        <TextView
            android:id="@+id/tvHomeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textColor="#1B5E20"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Short description -->
        <TextView
            android:id="@+id/tvHomeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/home_description"
            android:textColor="#555555"
            android:textSize="14sp" />

        <!-- Input section card -->
        <LinearLayout
            android:id="@+id/inputCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Petrol type label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_petrol_type"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Petrol type spinner -->
            <Spinner
                android:id="@+id/spinnerPetrolType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp" />

            <!-- Petrol price input label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_petrol_price"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Petrol price input -->
            <EditText
                android:id="@+id/etPetrolPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Example: 4.27"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:padding="10dp" />

            <!-- Fuel usage input label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_fuel_usage"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Fuel usage input -->
            <EditText
                android:id="@+id/etFuelUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Example: 40"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:padding="10dp" />

            <!-- Eligibility label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_budi_eligible"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- RadioGroup ensures user can only select Yes or No -->
            <RadioGroup
                android:id="@+id/rgEligibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbEligibleYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/option_yes"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbEligibleNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:checked="true"
                    android:text="@string/option_no"
                    android:textSize="15sp" />

            </RadioGroup>

            <!-- Calculate button -->
            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:backgroundTint="#1B5E20"
                android:text="@string/button_calculate"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <!-- Reset button -->
            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#757575"
                android:text="@string/button_reset"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Result section card -->
        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/result_title"
                android:textColor="#1B5E20"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTotalPetrolCost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/total_petrol_cost_default"
                android:textColor="#222222"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvBudiRebate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/budi_rebate_default"
                android:textColor="#222222"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTotalSaving"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/total_saving_default"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRebateNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/rebate_note"
                android:textColor="#777777"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>